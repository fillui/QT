  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background: #eef2f7;
}
QWidget {
    font-family: &quot;Microsoft YaHei UI&quot;, &quot;Microsoft YaHei&quot;, &quot;Segoe UI&quot;;
    font-size: 13px;
    color: #1f2937;
}
QFrame#headerFrame {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #0f172a, stop:1 #1e40af);
    border-radius: 18px;
}
QLabel#labelTitle {
    color: white;
    font-size: 24px;
    font-weight: 700;
}
QLabel#labelSubTitle {
    color: #dbeafe;
    font-size: 12px;
}
QLabel#labelStatusChip {
    background: rgba(255,255,255,0.16);
    color: white;
    border: 1px solid rgba(255,255,255,0.28);
    border-radius: 14px;
    padding: 6px 14px;
}
QTabWidget::pane {
    border: none;
    background: transparent;
    top: -1px;
}
QTabBar::tab {
    background: #dbe4f0;
    color: #475569;
    padding: 10px 22px;
    margin-right: 8px;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    min-width: 110px;
}
QTabBar::tab:selected {
    background: white;
    color: #1d4ed8;
    font-weight: 700;
}
QFrame#cardAnnotateImages,
QFrame#cardAnnotateCanvas,
QFrame#cardAnnotateInfo,
QFrame#cardTrainConfig,
QFrame#cardTrainLog,
QFrame#cardQuant,
QFrame#cardInfer,
QFrame#cardInferResult {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
}
QLabel[role=&quot;cardTitle&quot;] {
    font-size: 16px;
    font-weight: 700;
    color: #0f172a;
}
QLabel[role=&quot;hint&quot;] {
    color: #64748b;
    font-size: 12px;
}
QLineEdit, QSpinBox, QDoubleSpinBox, QComboBox {
    min-height: 34px;
    background: #f8fafc;
    border: 1px solid #cbd5e1;
    border-radius: 9px;
    padding: 4px 9px;
}
QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus, QComboBox:focus {
    border: 1px solid #2563eb;
    background: white;
}
QPushButton {
    min-height: 34px;
    background: #2563eb;
    color: white;
    border: none;
    border-radius: 10px;
    padding: 6px 14px;
    font-weight: 600;
}
QPushButton:hover {
    background: #1d4ed8;
}
QPushButton:pressed {
    background: #1e3a8a;
}
QPushButton#btnStopTrain,
QPushButton#btnStopQuant,
QPushButton#btnDeleteLabel,
QPushButton#btnDeleteClass,
QPushButton#btnClearAnnotation {
    background: #ef4444;
}
QPushButton#btnStopTrain:hover,
QPushButton#btnStopQuant:hover,
QPushButton#btnDeleteLabel:hover,
QPushButton#btnDeleteClass:hover,
QPushButton#btnClearAnnotation:hover {
    background: #dc2626;
}
QPushButton#btnSelectDataset,
QPushButton#btnSelectPythonExe,
QPushButton#btnSelectScript,
QPushButton#btnOpenImageDir,
QPushButton#btnSelectModelPath,
QPushButton#btnSelectCalibDir,
QPushButton#btnSelectOutputPath,
QPushButton#btnSelectInferPtModelPath,
QPushButton#btnSelectInferOnnxModelPath,
QPushButton#btnSelectInferImage {
    background: #475569;
}
QPushButton#btnSelectDataset:hover,
QPushButton#btnSelectPythonExe:hover,
QPushButton#btnSelectScript:hover,
QPushButton#btnOpenImageDir:hover,
QPushButton#btnSelectModelPath:hover,
QPushButton#btnSelectCalibDir:hover,
QPushButton#btnSelectOutputPath:hover,
QPushButton#btnSelectInferPtModelPath:hover,
QPushButton#btnSelectInferOnnxModelPath:hover,
QPushButton#btnSelectInferImage:hover {
    background: #334155;
}
QListWidget, QPlainTextEdit, QTextEdit, QTableWidget {
    background: #f8fafc;
    border: 1px solid #dbe4f0;
    border-radius: 12px;
    padding: 6px;
    selection-background-color: #bfdbfe;
    selection-color: #0f172a;
}

QGroupBox#groupBoxTrainResult {
    background: #ffffff;
    border: 1px solid #dbeafe;
    border-radius: 14px;
    margin-top: 14px;
    padding: 12px;
    font-weight: 700;
    color: #1d4ed8;
}
QGroupBox#groupBoxTrainResult::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 8px;
    background: white;
}
QTableWidget#tableWidgetTrainMetrics {
    background: #ffffff;
    gridline-color: #dbeafe;
    border: 1px solid #bfdbfe;
    border-radius: 10px;
}
QTextEdit#plainTextEditMetricChart {
    background: #0f172a;
    color: #e5e7eb;
    border: 1px solid #1e3a8a;
    border-radius: 10px;
    padding: 8px;
}

QHeaderView::section {
    background: #e2e8f0;
    color: #334155;
    border: none;
    padding: 8px;
    font-weight: 700;
}
QProgressBar {
    height: 18px;
    background: #e2e8f0;
    border-radius: 9px;
    text-align: center;
    color: #0f172a;
}
QProgressBar::chunk {
    border-radius: 9px;
    background: #22c55e;
}
QLabel#labelImage {
    background: #0f172a;
    color: #94a3b8;
    border: 1px solid #1e293b;
    border-radius: 14px;
}
ImageCanvas#canvasWidget {
    background: #111827;
    border: 1px solid #1f2937;
    border-radius: 14px;
}</string>
